// Firestore security rules — paste into Firebase Console → Firestore → Rules
// These rules:
//   • Scope mood_entries to the owning user (userId)
//   • Restrict Mood Connections data to the two connected users
//   • Block all access when a connection is pending / ended / blocked
//   • Prevent cross-connection data leakage
//
// Deploy: copy this file's contents to Firebase Console → Firestore Database → Rules → Publish.

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ─── Personal mood entries ────────────────────────────────
    match /mood_entries/{entryId} {
      allow read: if request.auth != null
                  && resource.data.userId == request.auth.uid;

      allow create: if request.auth != null
                    && request.resource.data.userId == request.auth.uid;

      allow update, delete: if request.auth != null
                            && resource.data.userId == request.auth.uid;
    }

    // ─── Mood Connections ─────────────────────────────────────
    match /connections/{connectionId} {

      function isMember() {
        return request.auth != null && (
          resource.data.userA == request.auth.uid ||
          resource.data.userB == request.auth.uid
        );
      }

      function isActive() {
        return resource.data.status == 'active';
      }

      // Read: members can read pending (to see their code) and active.
      allow read: if request.auth != null && (
        resource.data.userA == request.auth.uid ||
        resource.data.userB == request.auth.uid ||
        // Allow looking up by inviteCode to accept (query-scoped)
        resource.data.status == 'pending'
      );

      // Create: must be a pending invite owned by the caller
      allow create: if request.auth != null
                    && request.resource.data.userA == request.auth.uid
                    && request.resource.data.status == 'pending'
                    && request.resource.data.userB == null;

      // Update: either member can update.
      //   - Accepting: pending → active, userB becomes caller
      //   - Ending: active → ended (member only)
      allow update: if request.auth != null && (
        // Accept invite
        (resource.data.status == 'pending'
          && request.resource.data.status == 'active'
          && request.resource.data.userB == request.auth.uid
          && resource.data.userA != request.auth.uid)
        ||
        // Member ending connection
        (isMember() && request.resource.data.status == 'ended')
      );

      allow delete: if false;

      // ─── Subcollections ─ only for ACTIVE members ──────────
      match /moods/{moodId} {
        function parentActive() {
          let parent = get(/databases/$(database)/documents/connections/$(connectionId)).data;
          return parent.status == 'active'
                 && (parent.userA == request.auth.uid || parent.userB == request.auth.uid);
        }
        allow read: if request.auth != null && parentActive();
        allow create: if request.auth != null
                      && parentActive()
                      && request.resource.data.senderId == request.auth.uid;
        allow update, delete: if false;
      }

      match /messages/{messageId} {
        function parentActive() {
          let parent = get(/databases/$(database)/documents/connections/$(connectionId)).data;
          return parent.status == 'active'
                 && (parent.userA == request.auth.uid || parent.userB == request.auth.uid);
        }
        allow read: if request.auth != null && parentActive();
        allow create: if request.auth != null
                      && parentActive()
                      && request.resource.data.senderId == request.auth.uid;
        // Allow members to mark a letter as opened. Sender + content cannot change.
        allow update: if request.auth != null
                      && parentActive()
                      && request.resource.data.senderId == resource.data.senderId
                      && request.resource.data.type == resource.data.type
                      && request.resource.data.createdAt == resource.data.createdAt;
        allow delete: if false;

        match /reactions/{reactionId} {
          function grandparentActive() {
            let parent = get(/databases/$(database)/documents/connections/$(connectionId)).data;
            return parent.status == 'active'
                   && (parent.userA == request.auth.uid || parent.userB == request.auth.uid);
          }
          allow read: if request.auth != null && grandparentActive();
          allow create, update: if request.auth != null
                                && grandparentActive()
                                && request.resource.data.userId == request.auth.uid
                                && reactionId == request.auth.uid;
          allow delete: if request.auth != null
                        && grandparentActive()
                        && resource.data.userId == request.auth.uid;
        }
      }
    }

    // ─── Pet Growth ───────────────────────────────────────────
    // Owner doc id is either "u_{uid}" (personal) or "c_{cid}" (shared).
    // `members` array on the doc lists which uids may read/write.
    match /pets/{ownerKey} {
      function isMember() {
        return request.auth != null
               && resource.data.members.hasAny([request.auth.uid]);
      }
      function newIsMember() {
        return request.auth != null
               && request.resource.data.members.hasAny([request.auth.uid]);
      }
      allow read: if isMember();
      allow create: if newIsMember();
      allow update: if isMember() && newIsMember();
      allow delete: if false;

      match /items/{itemId} {
        // Defensive parent lookup: if parent or members is missing, returns false instead of erroring.
        function parentMember() {
          let parent = get(/databases/$(database)/documents/pets/$(ownerKey));
          return request.auth != null
                 && parent != null
                 && parent.data.keys().hasAny(['members'])
                 && parent.data.members.hasAny([request.auth.uid]);
        }
        // Item-level ownership check — works even if parent doc read fails.
        function itemMember() {
          return request.auth != null
                 && request.resource.data.keys().hasAny(['members'])
                 && request.resource.data.members.hasAny([request.auth.uid])
                 && request.resource.data.createdBy == request.auth.uid;
        }
        function existingItemMember() {
          return request.auth != null
                 && resource.data.keys().hasAny(['members'])
                 && resource.data.members.hasAny([request.auth.uid]);
        }
        allow read:   if parentMember() || existingItemMember();
        allow create: if itemMember();
        allow update: if (parentMember() || existingItemMember())
                      && request.resource.data.createdBy == resource.data.createdBy;
        allow delete: if existingItemMember();
      }
    }
  }
}
