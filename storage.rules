// Firebase Storage security rules — paste into Firebase Console → Storage → Rules
// Drawings are stored at: connections/{connectionId}/{uid}-{timestamp}.png
// Only the two ACTIVE members of the connection can read/write.

rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    match /connections/{connectionId}/{fileName} {
      function parentActive() {
        let parent = firestore.get(/databases/(default)/documents/connections/$(connectionId)).data;
        return parent.status == 'active'
               && (parent.userA == request.auth.uid || parent.userB == request.auth.uid);
      }

      allow read: if request.auth != null && parentActive();

      allow write: if request.auth != null
                   && parentActive()
                   && fileName.matches(request.auth.uid + '-.*\\.png')
                   && request.resource.size < 2 * 1024 * 1024
                   && request.resource.contentType.matches('image/.*');
    }

    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
